# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Cloudflare AI Gateway
CF_ACCOUNT_ID=your_cloudflare_account_id_here
CF_GATEWAY_ID=your_cloudflare_gateway_name_here

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/toxic_bot

# Superadmin Telegram user IDs (comma-separated integers)
SUPERADMIN_IDS=123456789,987654321

# Bot owner identity. When a message is from OWNER_USER_ID (PM or group post)
# or sent on behalf of OWNER_CHANNEL_ID (sender_chat in a group),
# the bot drops its toxic persona and replies as a loyal helpful assistant.
# Both fields are optional — leave blank or set to 0 to disable.
# Channel IDs are typically negative (e.g. -1001234567890).
OWNER_USER_ID=
OWNER_CHANNEL_ID=

# Set automatically by setup_commands.py after first successful run
# Remove this line or run with --force to re-register commands
# COMMANDS_REGISTERED=1
