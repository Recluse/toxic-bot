# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Cloudflare AI Gateway
CF_ACCOUNT_ID=your_cloudflare_account_id_here
CF_GATEWAY_ID=your_cloudflare_gateway_name_here

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/toxic_bot

# Superadmin Telegram user IDs (comma-separated integers)
SUPERADMIN_IDS=123456789,987654321

# Set automatically by setup_commands.py after first successful run
# Remove this line or run with --force to re-register commands
# COMMANDS_REGISTERED=1
